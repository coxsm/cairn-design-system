{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/sheet/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inknut Antiqua))/i]",
        "message": "Font not provided by the design system. Available: Inknut Antiqua."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConditionMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|showIcon|size|key|ref|className|style|children)$/]",
        "message": "<ConditionMark> doesn't accept that prop. Declared props: label, checked, showIcon, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='CurrencyPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:gp|sp|cp|size|key|ref|className|style|children)$/]",
        "message": "<CurrencyPanel> doesn't accept that prop. Declared props: gp, sp, cp, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='FieldLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|area|size|key|ref|className|style|children)$/]",
        "message": "<FieldLine> doesn't accept that prop. Declared props: label, value, area, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='FieldLine'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:base|lg)$/]",
        "message": "<FieldLine> size must be one of 'base' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|title|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, title, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='InventoryItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|fatigue|key|ref|className|style|children)$/]",
        "message": "<InventoryItem> doesn't accept that prop. Declared props: text, fatigue."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: children, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:base|lg)$/]",
        "message": "<SectionHeading> size must be one of 'base' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SheetPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|padded|key|ref|className|style|children)$/]",
        "message": "<SheetPanel> doesn't accept that prop. Declared props: children, style, padded."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|max|size|split|accent|label|key|ref|className|style|children)$/]",
        "message": "<StatBadge> doesn't accept that prop. Declared props: icon, value, max, size, split, accent, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBadge'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:crimson|)$/]",
        "message": "<StatBadge> accent must be one of 'crimson' | ''."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ConditionMark": {
        "replaces": []
      },
      "CurrencyPanel": {
        "replaces": []
      },
      "FieldLine": {
        "replaces": []
